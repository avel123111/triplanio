# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — used both for the redirect-flow button and the One Tap prompt
# on the Login page. Must also be added to Supabase Dashboard → Auth →
# Providers → Google → "Authorized Client IDs (for Sign in with Google)".
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Triplanio AI assistant bot — its user_id (uuid) in public.users. Per-environment.
# Used to detect bot-authored chat messages and resolve the bot avatar.
VITE_TRIPLANIO_BOT_USER_ID=

# Mapbox — public token (pk....) for the map surfaces (trip Map lens, planner
# previews, mini-map). Restrict it by URL (your domains + localhost) in the
# Mapbox account. Ships in the bundle by design.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
