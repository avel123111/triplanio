# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — used both for the redirect-flow button and the One Tap prompt
# on the Login page. Must also be added to Supabase Dashboard → Auth →
# Providers → Google → "Authorized Client IDs (for Sign in with Google)".
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
