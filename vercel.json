{
  "rewrites": [
    {
      "source": "/join/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*([Bb]ot|facebookexternalhit|Facebot|WhatsApp|Telegram|Slack|Discord|LinkedIn|Pinterest|vkShare|Embedly|SkypeUriPreview|Twitter).*"
        }
      ],
      "destination": "/join-og.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
